@model LibraryMS.Models.Category
@{
    ViewData["Title"] = "Kategori Sil";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-danger"><i class="bi bi-trash3 me-2"></i>Kategori Sil</h2>
    <a asp-action="CategoryIndex" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Geri</a>
</div>
<div class="card border-danger">
    <div class="card-header bg-danger text-white">
        <h5 class="mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Silme Onayı</h5>
    </div>
    <div class="card-body">
        <div class="alert alert-warning"><i class="bi bi-exclamation-circle me-2"></i>Bu kategoriyi silmek istediğinizden emin misiniz?</div>
        <dl class="row">
            <dt class="col-sm-3">Kategori Adı</dt><dd class="col-sm-9 fw-bold">@Model.Name</dd>
            <dt class="col-sm-3">Açıklama</dt><dd class="col-sm-9">@(Model.Description ?? "-")</dd>
            <dt class="col-sm-3">Kitap Sayısı</dt><dd class="col-sm-9"><span class="badge bg-primary">@(Model.Books?.Count ?? 0)</span></dd>
        </dl>
        <form asp-action="CategoryDelete">
            <input type="hidden" asp-for="CategoryId" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger"><i class="bi bi-trash3 me-1"></i>Evet, Sil</button>
                <a asp-action="CategoryIndex" class="btn btn-outline-secondary"><i class="bi bi-x-circle me-1"></i>Vazgeç</a>
            </div>
        </form>
    </div>
</div>

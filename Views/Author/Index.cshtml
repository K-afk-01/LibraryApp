@model IEnumerable<LibraryMS.Models.Author>
@{
    ViewData["Title"] = "Yazarlar";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="bi bi-person-lines-fill me-2 text-success"></i>Yazarlar</h2>
    <a asp-action="Create" class="btn btn-success"><i class="bi bi-person-plus me-1"></i>Yeni Yazar</a>
</div>
<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Ad</th>
                    <th>Soyad</th>
                    <th>E-posta</th>
                    <th>Doğum Tarihi</th>
                    <th>Kitap Sayısı</th>
                    <th class="text-center">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.FirstName</td>
                        <td class="fw-semibold">@item.LastName</td>
                        <td><a href="mailto:@item.Email">@(item.Email ?? "-")</a></td>
                        <td>@(item.BirthDate?.ToString("dd.MM.yyyy") ?? "-")</td>
                        <td><span class="badge bg-success">@(item.Books?.Count ?? 0) kitap</span></td>
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@item.AuthorId" class="btn btn-outline-info btn-action" title="Detay">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@item.AuthorId" class="btn btn-outline-warning btn-action" title="Düzenle">
                                <i class="bi bi-pencil-square"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.AuthorId" class="btn btn-outline-danger btn-action" title="Sil">
                                <i class="bi bi-trash3"></i>
                            </a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4"><i class="bi bi-inbox fs-3 d-block mb-2"></i>Henüz yazar eklenmemiş.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@{
    ViewData["Title"] = "Giriş Yap";
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>LibraryMS - Giriş</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        * { font-family: 'Inter', system-ui, -apple-system, sans-serif; }
        body {
            background: #1e2a4a;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
        }
        .login-card {
            width: 440px;
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 25px 60px rgba(0,0,0,0.3);
            padding: 40px 36px;
        }
        .brand-icon {
            width: 64px; height: 64px; border-radius: 50%;
            background: #eef0f5;
            color: #081534;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.6rem;
            margin: 0 auto 16px;
        }
        .brand-title { text-align: center; font-weight: 700; color: #081534; font-size: 1.7rem; margin: 0; }
        .brand-sub { text-align: center; color: #76777f; font-size: 0.95rem; margin: 4px 0 28px; }
        .lms-label { font-size: 0.88rem; font-weight: 600; color: #191c1f; margin-bottom: 6px; display: block; }
        .lms-input {
            width: 100%; border: 1px solid #d1d5db;
            border-radius: 8px; padding: 11px 14px;
            font-size: 0.92rem; background: #fff;
            outline: none;
        }
        .lms-input:focus { border-color: #2170e4; box-shadow: 0 0 0 3px rgba(33,112,228,0.15); }
        .input-with-icon { position: relative; }
        .input-with-icon .toggle-eye {
            position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
            background: transparent; border: none; color: #76777f; cursor: pointer;
        }
        .btn-login {
            width: 100%; background: #081534; color: #fff;
            border: none; padding: 12px;
            border-radius: 8px; font-weight: 600;
            font-size: 0.95rem; margin-top: 8px;
        }
        .btn-login:hover { background: #1e2a4a; }
        .demo-hint {
            margin-top: 20px;
            background: #f2f3f7;
            border-radius: 8px;
            text-align: center;
            padding: 10px;
            color: #45464e;
            font-size: 0.85rem;
        }
    </style>
</head>
<body>
<div class="login-card">
    <div class="brand-icon"><i class="bi bi-book-half"></i></div>
    <h1 class="brand-title">LibraryMS</h1>
    <p class="brand-sub">Kitap Yönetim Sistemi</p>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success" style="border:none; background:#d6f5e3; color:#0b6b34; border-radius:8px;"><i class="bi bi-check-circle me-2"></i>@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger" style="border:none; background:#ffdad6; color:#93000a; border-radius:8px;"><i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]</div>
    }
    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger" style="border:none; background:#ffdad6; color:#93000a; border-radius:8px;"><i class="bi bi-exclamation-triangle me-2"></i>@ViewBag.Error</div>
    }

    <form method="post" asp-controller="Account" asp-action="Login">
        @Html.AntiForgeryToken()
        <div class="mb-3">
            <label class="lms-label">Kullanıcı Adı</label>
            <input type="text" name="username" class="lms-input" placeholder="admin" required />
        </div>
        <div class="mb-3">
            <label class="lms-label">Şifre</label>
            <div class="input-with-icon">
                <input type="password" id="pwd" name="password" class="lms-input" placeholder="••••••••" required />
                <button type="button" class="toggle-eye" onclick="(function(){var i=document.getElementById('pwd');i.type=i.type==='password'?'text':'password';})()">
                    <i class="bi bi-eye"></i>
                </button>
            </div>
        </div>
        <button type="submit" class="btn-login">Giriş Yap</button>
    </form>

    <div class="demo-hint">
        <i class="bi bi-info-circle me-1"></i>
        Demo Girişi: <strong>admin</strong> / <strong>Admin123!</strong>
    </div>
</div>
</body>
</html>

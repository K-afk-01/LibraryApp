@model LibraryMS.Models.Book
@{
    ViewData["Title"] = "Kitap Detayı";
}
<div class="row g-3">
    <div class="col-lg-4">
        <div class="lms-card" style="padding:20px;display:flex;align-items:center;justify-content:center;min-height:360px;background:#f2f3f7;position:relative;">
            <div style="position:absolute;top:14px;right:14px;background:#fff;border-radius:999px;padding:4px 10px;font-size:0.78rem;font-weight:600;color:#45464e;box-shadow:0 1px 4px rgba(0,0,0,0.08);">
                <i class="bi bi-star-fill" style="color:#f59e0b;"></i> 4.8
            </div>
            <div style="width:160px;height:240px;background:#1e2a4a;border-radius:8px;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:600;text-align:center;padding:16px;box-shadow:0 8px 24px rgba(0,0,0,0.18);">
                @Model.Title
            </div>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="lms-card" style="border-top:4px solid #2170e4;">
            <div class="lms-card-body">
                <div class="d-flex justify-content-between align-items-start mb-3 flex-wrap gap-2">
                    <div>
                        <h2 style="margin:0;font-weight:700;color:#081534;font-size:1.5rem;">@Model.Title</h2>
                        <div style="color:#45464e;">@Model.Author?.FullName</div>
                    </div>
                    <span class="lms-badge lms-badge-blue">@Model.Category?.Name</span>
                </div>

                <div class="row g-3 mt-2">
                    <div class="col-md-6">
                        <div class="d-flex gap-3 align-items-start">
                            <div style="width:36px;height:36px;border-radius:8px;background:#eef0f5;display:flex;align-items:center;justify-content:center;color:#45464e;"><i class="bi bi-upc"></i></div>
                            <div>
                                <div style="font-size:0.78rem;color:#76777f;font-weight:600;">ISBN / Barkod</div>
                                <div style="font-weight:600;">@Model.ISBN</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex gap-3 align-items-start">
                            <div style="width:36px;height:36px;border-radius:8px;background:#fff4cc;display:flex;align-items:center;justify-content:center;color:#6e5300;"><i class="bi bi-currency-exchange"></i></div>
                            <div>
                                <div style="font-size:0.78rem;color:#76777f;font-weight:600;">Fiyat</div>
                                <span class="lms-badge lms-badge-yellow" style="font-size:0.85rem;">@Model.Price.ToString("C2")</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex gap-3 align-items-start">
                            <div style="width:36px;height:36px;border-radius:8px;background:#eef0f5;display:flex;align-items:center;justify-content:center;color:#45464e;"><i class="bi bi-archive"></i></div>
                            <div>
                                <div style="font-size:0.78rem;color:#76777f;font-weight:600;">Stok Durumu</div>
                                <div style="font-weight:600;">
                                    <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:@(Model.Stock>5?"#16a34a":"#dc2626");margin-right:6px;"></span>
                                    @Model.Stock Adet Mevcut
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex gap-3 align-items-start">
                            <div style="width:36px;height:36px;border-radius:8px;background:#eef0f5;display:flex;align-items:center;justify-content:center;color:#45464e;"><i class="bi bi-person"></i></div>
                            <div>
                                <div style="font-size:0.78rem;color:#76777f;font-weight:600;">Yazar ID</div>
                                <div style="font-weight:600;">AUT-@Model.AuthorId</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex gap-3 align-items-start">
                            <div style="width:36px;height:36px;border-radius:8px;background:#eef0f5;display:flex;align-items:center;justify-content:center;color:#45464e;"><i class="bi bi-calendar"></i></div>
                            <div>
                                <div style="font-size:0.78rem;color:#76777f;font-weight:600;">Basım Yılı</div>
                                <div style="font-weight:600;">@(Model.PublishDate?.ToString("yyyy") ?? "Belirtilmemiş")</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex gap-3 align-items-start">
                            <div style="width:36px;height:36px;border-radius:8px;background:#eef0f5;display:flex;align-items:center;justify-content:center;color:#45464e;"><i class="bi bi-building"></i></div>
                            <div>
                                <div style="font-size:0.78rem;color:#76777f;font-weight:600;">Yayınevi</div>
                                <div style="font-weight:600;">LibraryMS Yayınları</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div style="padding:16px 24px;border-top:1px solid var(--lms-border);display:flex;justify-content:flex-end;gap:10px;">
                <a asp-action="Edit" asp-route-id="@Model.BookId" class="lms-btn-outline"><i class="bi bi-pencil"></i>Düzenle</a>
                <a asp-action="Delete" asp-route-id="@Model.BookId" class="lms-btn-danger"><i class="bi bi-trash3"></i>Sil</a>
            </div>
        </div>
    </div>
</div>

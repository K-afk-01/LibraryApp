@model List<LibraryMS.Models.BookReportViewModel>
@{
    ViewData["Title"] = "Kitap Raporu";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="bi bi-file-earmark-bar-graph me-2 text-success"></i>Kitap Raporu</h2>
    <span class="badge bg-secondary fs-6"><i class="bi bi-gear me-1"></i>GetBookReport (Stored Procedure)</span>
</div>
<div class="card">
    <div class="card-header bg-success text-white">
        <h5 class="mb-0"><i class="bi bi-table me-2"></i>Tüm Kitaplar - Detaylı Rapor</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th><i class="bi bi-hash me-1"></i>#</th>
                        <th><i class="bi bi-book me-1"></i>Kitap Adı</th>
                        <th><i class="bi bi-upc me-1"></i>ISBN</th>
                        <th><i class="bi bi-currency-dollar me-1"></i>Fiyat</th>
                        <th><i class="bi bi-person me-1"></i>Yazar</th>
                        <th><i class="bi bi-tag me-1"></i>Kategori</th>
                        <th><i class="bi bi-boxes me-1"></i>Stok</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.BookId</td>
                            <td class="fw-semibold">@item.Title</td>
                            <td><code>@item.ISBN</code></td>
                            <td><span class="badge bg-success">@item.Price.ToString("C2")</span></td>
                            <td>@item.AuthorName</td>
                            <td><span class="badge bg-primary">@item.CategoryName</span></td>
                            <td>
                                @if (item.Stock <= 5) {
                                    <span class="badge bg-danger"><i class="bi bi-exclamation-triangle me-1"></i>@item.Stock</span>
                                } else {
                                    <span class="badge bg-success">@item.Stock</span>
                                }
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="7" class="text-center text-muted py-4"><i class="bi bi-inbox fs-3 d-block mb-2"></i>Henüz kitap bulunmamaktadır.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer text-muted">
        <small><i class="bi bi-info-circle me-1"></i>Bu rapor <strong>GetBookReport</strong> stored procedure kullanılarak oluşturulmuştur. Toplam: <strong>@Model.Count</strong> kitap</small>
    </div>
</div>

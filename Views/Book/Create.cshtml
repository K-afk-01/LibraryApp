@model LibraryMS.Models.Book
@{
    ViewData["Title"] = "Yeni Kitap Ekle";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="bi bi-plus-circle me-2 text-primary"></i>Yeni Kitap Ekle</h2>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Geri</a>
</div>
<div class="card">
    <div class="card-body">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Title" class="form-label fw-semibold"></label>
                    <input asp-for="Title" class="form-control" placeholder="Kitap adını giriniz" />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="ISBN" class="form-label fw-semibold"></label>
                    <input asp-for="ISBN" class="form-control" placeholder="978-x-xxx-xxxxx-x" />
                    <span asp-validation-for="ISBN" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Price" class="form-label fw-semibold"></label>
                    <div class="input-group">
                        <span class="input-group-text">₺</span>
                        <input asp-for="Price" class="form-control" placeholder="0.00" />
                    </div>
                    <span asp-validation-for="Price" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Stock" class="form-label fw-semibold"></label>
                    <input asp-for="Stock" class="form-control" type="number" min="0" />
                    <span asp-validation-for="Stock" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="PublishDate" class="form-label fw-semibold"></label>
                    <input asp-for="PublishDate" class="form-control" type="date" />
                    <span asp-validation-for="PublishDate" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="AuthorId" class="form-label fw-semibold"><i class="bi bi-person me-1"></i>Yazar</label>
                    <select asp-for="AuthorId" asp-items="ViewBag.AuthorId" class="form-select">
                        <option value="">-- Yazar Seçiniz --</option>
                    </select>
                    <span asp-validation-for="AuthorId" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="CategoryId" class="form-label fw-semibold"><i class="bi bi-tag me-1"></i>Kategori</label>
                    <select asp-for="CategoryId" asp-items="ViewBag.CategoryId" class="form-select">
                        <option value="">-- Kategori Seçiniz --</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger small"></span>
                </div>
            </div>
            <hr class="mt-4" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-floppy me-1"></i>Kaydet</button>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-x-circle me-1"></i>İptal</a>
            </div>
        </form>
    </div>
</div>
@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }

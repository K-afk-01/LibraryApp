@{
    ViewData["Title"] = "Ana Sayfa";
    var stats = ViewBag.Stats;
}

<h1 class="lms-page-title">Ana Sayfa</h1>

<div class="row g-3 mt-2">
    <div class="col-lg-8">
        <div class="row g-3">
            <div class="col-md-6">
                <div class="lms-card p-3" style="border-left:4px solid #2170e4;">
                    <div class="d-flex align-items-center gap-3">
                        <div style="width:48px;height:48px;border-radius:10px;background:#dae8ff;color:#0058be;display:flex;align-items:center;justify-content:center;font-size:1.3rem;">
                            <i class="bi bi-book"></i>
                        </div>
                        <div>
                            <div style="font-size:0.72rem;font-weight:600;color:#76777f;text-transform:uppercase;letter-spacing:0.04em;">Toplam Kitap</div>
                            <div style="font-size:1.7rem;font-weight:700;color:#081534;">@stats.Books</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="lms-card p-3">
                    <div class="d-flex align-items-center gap-3">
                        <div style="width:48px;height:48px;border-radius:10px;background:#eef0f5;color:#45464e;display:flex;align-items:center;justify-content:center;font-size:1.3rem;">
                            <i class="bi bi-person"></i>
                        </div>
                        <div>
                            <div style="font-size:0.72rem;font-weight:600;color:#76777f;text-transform:uppercase;letter-spacing:0.04em;">Toplam Yazar</div>
                            <div style="font-size:1.7rem;font-weight:700;color:#081534;">@stats.Authors</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="lms-card p-3">
                    <div class="d-flex align-items-center gap-3">
                        <div style="width:48px;height:48px;border-radius:10px;background:#fff0d9;color:#594317;display:flex;align-items:center;justify-content:center;font-size:1.3rem;">
                            <i class="bi bi-diagram-3"></i>
                        </div>
                        <div>
                            <div style="font-size:0.72rem;font-weight:600;color:#76777f;text-transform:uppercase;letter-spacing:0.04em;">Toplam Kategori</div>
                            <div style="font-size:1.7rem;font-weight:700;color:#081534;">@stats.Categories</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="lms-card p-3" style="border-left:4px solid #dc2626;">
                    <div class="d-flex align-items-center gap-3">
                        <div style="width:48px;height:48px;border-radius:10px;background:#ffdad6;color:#93000a;display:flex;align-items:center;justify-content:center;font-size:1.3rem;">
                            <i class="bi bi-cart3"></i>
                        </div>
                        <div>
                            <div style="font-size:0.72rem;font-weight:600;color:#76777f;text-transform:uppercase;letter-spacing:0.04em;">Toplam Sipariş</div>
                            <div style="font-size:1.7rem;font-weight:700;color:#081534;">@stats.Orders</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-12">
                <div class="lms-card p-3 d-flex align-items-center justify-content-between flex-wrap gap-3">
                    <div>
                        <div style="font-weight:600;font-size:1rem;color:#081534;">Raporlar ve Analizler</div>
                        <div style="color:#76777f;font-size:0.85rem;max-width:480px;">Kütüphane envanteri ve kullanıcı aktiviteleri hakkında detaylı aylık raporları inceleyin.</div>
                    </div>
                    <a asp-controller="Home" asp-action="Report" class="lms-btn-success">
                        <i class="bi bi-download"></i>Rapor İndir
                    </a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="lms-card p-3">
            <div style="font-weight:600;font-size:1rem;color:#081534;margin-bottom:14px;">Hızlı Erişim</div>
            <div class="row g-2">
                <div class="col-6">
                    <a asp-controller="Book" asp-action="Create" class="d-flex flex-column align-items-center justify-content-center text-decoration-none" style="background:#f2f3f7;border-radius:10px;padding:18px 8px;color:#081534;">
                        <i class="bi bi-plus-circle" style="font-size:1.4rem;color:#2170e4;"></i>
                        <span style="font-size:0.82rem;font-weight:600;margin-top:6px;">Yeni Kitap</span>
                    </a>
                </div>
                <div class="col-6">
                    <a asp-controller="Author" asp-action="OrderCreate" class="d-flex flex-column align-items-center justify-content-center text-decoration-none" style="background:#f2f3f7;border-radius:10px;padding:18px 8px;color:#081534;">
                        <i class="bi bi-cart-plus" style="font-size:1.4rem;color:#2170e4;"></i>
                        <span style="font-size:0.82rem;font-weight:600;margin-top:6px;">Yeni Sipariş</span>
                    </a>
                </div>
                <div class="col-6">
                    <a asp-controller="Home" asp-action="Report" class="d-flex flex-column align-items-center justify-content-center text-decoration-none" style="background:#f2f3f7;border-radius:10px;padding:18px 8px;color:#081534;">
                        <i class="bi bi-file-earmark-bar-graph" style="font-size:1.4rem;color:#45464e;"></i>
                        <span style="font-size:0.82rem;font-weight:600;margin-top:6px;">Rapor Al</span>
                    </a>
                </div>
                <div class="col-6">
                    <a href="#" class="d-flex flex-column align-items-center justify-content-center text-decoration-none" style="background:#f2f3f7;border-radius:10px;padding:18px 8px;color:#081534;">
                        <i class="bi bi-gear" style="font-size:1.4rem;color:#45464e;"></i>
                        <span style="font-size:0.82rem;font-weight:600;margin-top:6px;">Ayarlar</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

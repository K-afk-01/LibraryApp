@model LibraryMS.Models.Order
@{
    ViewData["Title"] = "Sipariş Düzenle";
}
<div class="d-flex align-items-center gap-2 mb-3">
    <a asp-action="OrderIndex" class="lms-icon-action" title="Geri"><i class="bi bi-arrow-left"></i></a>
    <h1 class="lms-page-title">Sipariş Düzenle</h1>
</div>

<div class="lms-card">
    <div class="lms-card-body">
        <form asp-action="OrderEdit">
            <input type="hidden" asp-for="OrderId" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="border:none;background:#ffdad6;color:#93000a;border-radius:8px;"></div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="CustomerName" class="lms-label">Müşteri Adı</label>
                    <input asp-for="CustomerName" class="lms-input" />
                    <span asp-validation-for="CustomerName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="CustomerEmail" class="lms-label">E-posta Adresi</label>
                    <input asp-for="CustomerEmail" class="lms-input" type="email" />
                    <span asp-validation-for="CustomerEmail" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="BookId" class="lms-label">Kitap</label>
                    <select asp-for="BookId" asp-items="ViewBag.BookId" class="lms-select"></select>
                    <span asp-validation-for="BookId" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Quantity" class="lms-label">Adet</label>
                    <input asp-for="Quantity" class="lms-input" type="number" min="1" />
                </div>
                <div class="col-md-3">
                    <label asp-for="Status" class="lms-label">Durum</label>
                    <select asp-for="Status" class="lms-select">
                        <option value="Beklemede">Bekliyor</option>
                        <option value="Tamamlandı">Tamamlandı</option>
                        <option value="İptal">İptal</option>
                    </select>
                </div>
            </div>
            <hr style="margin:24px 0;border-color:#e7e8ec;" />
            <div class="d-flex justify-content-end gap-2">
                <a asp-action="OrderIndex" class="lms-btn-outline">İptal</a>
                <button type="submit" class="lms-btn-primary"><i class="bi bi-floppy"></i>Güncelle</button>
            </div>
        </form>
    </div>
</div>
@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }

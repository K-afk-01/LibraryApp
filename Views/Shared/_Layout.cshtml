<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LibraryMS</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <style>
        body { background-color: #f8f9fa; }
        .sidebar { min-height: 100vh; background: linear-gradient(180deg, #1a237e 0%, #283593 100%); }
        .sidebar .nav-link { color: rgba(255,255,255,0.8); border-radius: 8px; margin: 2px 0; }
        .sidebar .nav-link:hover, .sidebar .nav-link.active { background: rgba(255,255,255,0.15); color: #fff; }
        .sidebar .nav-link i { width: 20px; }
        .sidebar-brand { color: #fff; font-size: 1.3rem; font-weight: 700; padding: 1rem; border-bottom: 1px solid rgba(255,255,255,0.2); }
        .main-content { padding: 1.5rem; }
        .card { border: none; box-shadow: 0 2px 8px rgba(0,0,0,0.08); border-radius: 12px; }
        .card-header { border-radius: 12px 12px 0 0 !important; }
        .table-hover tbody tr:hover { background-color: #f0f4ff; }
        .btn-action { padding: 4px 10px; font-size: 0.82rem; }
        .stat-card { background: linear-gradient(135deg, #1a237e, #3949ab); color: white; border-radius: 12px; }
    </style>
</head>
<body>
@if (Context.Session.GetString("Username") != null)
{
<div class="d-flex">
    <!-- Sidebar -->
    <nav class="sidebar d-flex flex-column p-3" style="width:240px; min-width:240px;">
        <div class="sidebar-brand mb-3">
            <i class="bi bi-book-half me-2"></i>LibraryMS
        </div>
        <ul class="nav flex-column gap-1">
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Home"?"active":"")" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-house-door me-2"></i>Ana Sayfa
                </a>
            </li>
            <li class="nav-item mt-2">
                <small class="text-white-50 text-uppercase px-2" style="font-size:0.7rem;">Kitap Yönetimi</small>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Book" && ViewContext.RouteData.Values["action"]?.ToString()!="CategoryIndex"?"active":"")" asp-controller="Book" asp-action="Index">
                    <i class="bi bi-book me-2"></i>Kitaplar
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString()=="CategoryIndex"?"active":"")" asp-controller="Book" asp-action="CategoryIndex">
                    <i class="bi bi-tags me-2"></i>Kategoriler
                </a>
            </li>
            <li class="nav-item mt-2">
                <small class="text-white-50 text-uppercase px-2" style="font-size:0.7rem;">Yazar & Sipariş</small>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Author" && ViewContext.RouteData.Values["action"]?.ToString()!="OrderIndex"?"active":"")" asp-controller="Author" asp-action="Index">
                    <i class="bi bi-person-lines-fill me-2"></i>Yazarlar
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString()=="OrderIndex"?"active":"")" asp-controller="Author" asp-action="OrderIndex">
                    <i class="bi bi-cart3 me-2"></i>Siparişler
                </a>
            </li>
            <li class="nav-item mt-2">
                <small class="text-white-50 text-uppercase px-2" style="font-size:0.7rem;">Raporlar</small>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString()=="Report"?"active":"")" asp-controller="Home" asp-action="Report">
                    <i class="bi bi-file-earmark-bar-graph me-2"></i>Kitap Raporu
                </a>
            </li>
        </ul>
        <div class="mt-auto pt-3 border-top border-secondary">
            <div class="text-white-50 small mb-2"><i class="bi bi-person-circle me-1"></i>@Context.Session.GetString("Username")</div>
            <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-light btn-sm w-100">
                <i class="bi bi-box-arrow-right me-1"></i>Çıkış Yap
            </a>
        </div>
    </nav>

    <!-- Main -->
    <div class="flex-grow-1">
        <main class="main-content">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </main>
    </div>
</div>
}
else
{
    @RenderBody()
}
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>

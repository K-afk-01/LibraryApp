@model IEnumerable<LibraryMS.Models.Order>
@{
    ViewData["Title"] = "Siparişler";
}
<div class="d-flex justify-content-between align-items-start mb-3 flex-wrap gap-2">
    <div>
        <h1 class="lms-page-title"><i class="bi bi-cart3" style="color:#45464e;"></i>Siparişler</h1>
        <p class="lms-page-sub">Tüm kullanıcı siparişlerini yönetin ve takip edin.</p>
    </div>
    <a asp-action="OrderCreate" class="lms-btn-primary"><i class="bi bi-plus-lg"></i>Yeni Sipariş</a>
</div>

<div class="lms-card">
    <div style="padding:14px 20px;border-bottom:1px solid var(--lms-border);display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;">
        <div class="lms-search" style="max-width:320px;flex-grow:1;">
            <i class="bi bi-search"></i>
            <input type="text" placeholder="Sipariş ID, Müşteri Ara..." />
        </div>
        <div class="d-flex gap-2">
            <button class="lms-btn-outline" type="button"><i class="bi bi-funnel"></i>Filtrele</button>
            <button class="lms-btn-outline" type="button"><i class="bi bi-download"></i>Dışa Aktar</button>
        </div>
    </div>
    <div class="table-responsive">
        <table class="lms-table">
            <thead>
                <tr>
                    <th>#ID</th>
                    <th>Müşteri Adı</th>
                    <th>E-posta</th>
                    <th>Kitap</th>
                    <th>Adet</th>
                    <th>Toplam (₺)</th>
                    <th>Tarih</th>
                    <th>Durum</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td style="color:#45464e;font-weight:600;">ORD-@item.OrderId.ToString("D4")</td>
                        <td style="font-weight:600;color:#081534;">@item.CustomerName</td>
                        <td><a href="mailto:@item.CustomerEmail" style="color:#2170e4;text-decoration:none;">@item.CustomerEmail</a></td>
                        <td>@item.Book?.Title</td>
                        <td>@item.Quantity</td>
                        <td style="font-weight:600;">@item.TotalAmount.ToString("N2")</td>
                        <td style="color:#45464e;">@item.OrderDate.ToString("d MMM yyyy")</td>
                        <td>
                            @if (item.Status == "Tamamlandı")
                            {
                                <span class="lms-badge lms-badge-green">@item.Status</span>
                            }
                            else if (item.Status == "İptal")
                            {
                                <span class="lms-badge lms-badge-red">@item.Status</span>
                            }
                            else
                            {
                                <span class="lms-badge lms-badge-yellow">@item.Status</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="OrderEdit" asp-route-id="@item.OrderId" class="lms-icon-action" title="Düzenle"><i class="bi bi-pencil"></i></a>
                            <a asp-action="OrderDelete" asp-route-id="@item.OrderId" class="lms-icon-action danger" title="Sil"><i class="bi bi-trash3"></i></a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="9" class="text-center text-muted py-5"><i class="bi bi-inbox fs-3 d-block mb-2"></i>Henüz sipariş bulunmamaktadır.</td></tr>
                }
            </tbody>
        </table>
    </div>
    <div style="padding:14px 20px;border-top:1px solid var(--lms-border);color:#76777f;font-size:0.88rem;">
        Toplam @Model.Count() sipariş listeleniyor
    </div>
</div>

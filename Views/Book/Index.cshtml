@model IEnumerable<LibraryMS.Models.Book>
@{
    ViewData["Title"] = "Kitaplar";
}
<div class="d-flex justify-content-between align-items-start mb-3 flex-wrap gap-2">
    <div>
        <h1 class="lms-page-title"><i class="bi bi-book" style="color:#2170e4;"></i>Kitaplar</h1>
        <p class="lms-page-sub">Kütüphane envanterindeki tüm eserleri yönetin ve inceleyin.</p>
    </div>
    <a asp-action="Create" class="lms-btn-primary"><i class="bi bi-plus-lg"></i>Yeni Kitap Ekle</a>
</div>

<div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
    <div class="d-flex gap-2">
        <button class="lms-btn-outline" type="button"><i class="bi bi-funnel"></i>Filtrele</button>
        <button class="lms-btn-outline" type="button">Kategori: Tümü <i class="bi bi-chevron-down"></i></button>
    </div>
    <small style="color:#76777f;">Toplam <strong>@Model.Count()</strong> kitap listeleniyor</small>
</div>

<div class="lms-card">
    <div class="table-responsive">
        <table class="lms-table">
            <thead>
                <tr>
                    <th>Kitap Adı</th>
                    <th>ISBN</th>
                    <th>Fiyat</th>
                    <th>Yazar</th>
                    <th>Kategori</th>
                    <th>Stok</th>
                    <th>Yayın Tarihi</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-3">
                                <div style="width:36px;height:36px;border-radius:8px;background:#eef0f5;display:flex;align-items:center;justify-content:center;color:#45464e;">
                                    <i class="bi bi-journal-text"></i>
                                </div>
                                <span style="font-weight:600;color:#081534;">@item.Title</span>
                            </div>
                        </td>
                        <td style="color:#45464e;">@item.ISBN</td>
                        <td><span class="lms-badge lms-badge-yellow">@item.Price.ToString("C0")</span></td>
                        <td>@item.Author?.FullName</td>
                        <td><span class="lms-badge lms-badge-blue">@item.Category?.Name</span></td>
                        <td>
                            @if (item.Stock <= 5)
                            {
                                <span class="lms-badge lms-badge-red"><span style="width:6px;height:6px;border-radius:50%;background:#93000a;"></span>@item.Stock</span>
                            }
                            else
                            {
                                <span class="lms-badge lms-badge-gray"><span style="width:6px;height:6px;border-radius:50%;background:#45464e;"></span>@item.Stock</span>
                            }
                        </td>
                        <td>@(item.PublishDate?.ToString("yyyy") ?? "-")</td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@item.BookId" class="lms-icon-action" title="Detay"><i class="bi bi-eye"></i></a>
                            <a asp-action="Edit" asp-route-id="@item.BookId" class="lms-icon-action" title="Düzenle"><i class="bi bi-pencil"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.BookId" class="lms-icon-action danger" title="Sil"><i class="bi bi-trash3"></i></a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="8" class="text-center text-muted py-5"><i class="bi bi-inbox fs-3 d-block mb-2"></i>Henüz kitap eklenmemiş.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

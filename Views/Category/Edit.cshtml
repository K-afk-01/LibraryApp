@model LibraryMS.Models.Category
@{
    ViewData["Title"] = "Kategori Düzenle";
}
<div class="d-flex align-items-center gap-2 mb-3">
    <a asp-action="CategoryIndex" class="lms-icon-action" title="Geri"><i class="bi bi-arrow-left"></i></a>
    <h1 class="lms-page-title">Kategori Düzenle</h1>
</div>

<div class="lms-card">
    <div class="lms-card-body">
        <form asp-action="CategoryEdit">
            <input type="hidden" asp-for="CategoryId" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="border:none;background:#ffdad6;color:#93000a;border-radius:8px;"></div>
            <div class="lms-form-group">
                <label asp-for="Name" class="lms-label">Kategori Adı <span style="color:#dc2626;">*</span></label>
                <input asp-for="Name" class="lms-input" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="lms-form-group">
                <label asp-for="Description" class="lms-label">Açıklama</label>
                <textarea asp-for="Description" class="lms-textarea" rows="4"></textarea>
            </div>
            <hr style="margin:18px 0;border-color:#e7e8ec;" />
            <div class="d-flex justify-content-end gap-2">
                <a asp-action="CategoryIndex" class="lms-btn-outline">İptal</a>
                <button type="submit" class="lms-btn-primary"><i class="bi bi-floppy"></i>Güncelle</button>
            </div>
        </form>
    </div>
</div>
@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }

@model LibraryMS.Models.Author
@{
    ViewData["Title"] = "Yazar Detayı";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="bi bi-person-lines-fill me-2 text-info"></i>Yazar Detayı</h2>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Geri</a>
</div>
<div class="card">
    <div class="card-header bg-info text-white">
        <h5 class="mb-0"><i class="bi bi-person-circle me-2"></i>@Model.FullName</h5>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">E-posta</dt><dd class="col-sm-9"><a href="mailto:@Model.Email">@(Model.Email ?? "-")</a></dd>
            <dt class="col-sm-3">Doğum Tarihi</dt><dd class="col-sm-9">@(Model.BirthDate?.ToString("dd MMMM yyyy") ?? "-")</dd>
            <dt class="col-sm-3">Biyografi</dt><dd class="col-sm-9">@(Model.Bio ?? "-")</dd>
        </dl>
        @if (Model.Books != null && Model.Books.Any())
        {
            <h6 class="mt-3 fw-bold"><i class="bi bi-book me-2"></i>Kitapları</h6>
            <ul class="list-group list-group-flush">
                @foreach (var book in Model.Books)
                {
                    <li class="list-group-item d-flex justify-content-between">
                        <span>@book.Title</span>
                        <span class="badge bg-success">@book.Price.ToString("C2")</span>
                    </li>
                }
            </ul>
        }
        <div class="d-flex gap-2 mt-3">
            <a asp-action="Edit" asp-route-id="@Model.AuthorId" class="btn btn-warning"><i class="bi bi-pencil-square me-1"></i>Düzenle</a>
            <a asp-action="Delete" asp-route-id="@Model.AuthorId" class="btn btn-danger"><i class="bi bi-trash3 me-1"></i>Sil</a>
        </div>
    </div>
</div>

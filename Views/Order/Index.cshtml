@model IEnumerable<LibraryMS.Models.Order>
@{
    ViewData["Title"] = "Siparişler";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="bi bi-cart3 me-2 text-purple" style="color:#6a1b9a;"></i>Siparişler</h2>
    <a asp-action="OrderCreate" class="btn btn-purple" style="background:#6a1b9a;color:white;"><i class="bi bi-cart-plus me-1"></i>Yeni Sipariş</a>
</div>
<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Müşteri Adı</th>
                        <th>E-posta</th>
                        <th>Kitap</th>
                        <th>Adet</th>
                        <th>Toplam</th>
                        <th>Tarih</th>
                        <th>Durum</th>
                        <th class="text-center">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.OrderId</td>
                            <td class="fw-semibold">@item.CustomerName</td>
                            <td><a href="mailto:@item.CustomerEmail">@item.CustomerEmail</a></td>
                            <td>@item.Book?.Title</td>
                            <td>@item.Quantity</td>
                            <td><span class="badge bg-success">@item.TotalAmount.ToString("C2")</span></td>
                            <td>@item.OrderDate.ToString("dd.MM.yyyy")</td>
                            <td>
                                @if (item.Status == "Tamamlandı")
                                {
                                    <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>@item.Status</span>
                                }
                                else if (item.Status == "İptal")
                                {
                                    <span class="badge bg-danger"><i class="bi bi-x-circle me-1"></i>@item.Status</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark"><i class="bi bi-clock me-1"></i>@item.Status</span>
                                }
                            </td>
                            <td class="text-center">
                                <a asp-action="OrderEdit" asp-route-id="@item.OrderId" class="btn btn-outline-warning btn-action" title="Düzenle">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <a asp-action="OrderDelete" asp-route-id="@item.OrderId" class="btn btn-outline-danger btn-action" title="Sil">
                                    <i class="bi bi-trash3"></i>
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="9" class="text-center text-muted py-4"><i class="bi bi-inbox fs-3 d-block mb-2"></i>Henüz sipariş bulunmamaktadır.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@model LibraryMS.Models.Author
@{
    ViewData["Title"] = "Yeni Yazar";
}
<div class="d-flex align-items-center gap-2 mb-2">
    <a asp-action="Index" class="lms-icon-action" title="Geri"><i class="bi bi-arrow-left"></i></a>
    <h1 class="lms-page-title">Yeni Yazar Ekle</h1>
</div>
<p class="lms-page-sub" style="margin-left:44px;margin-bottom:18px;">Sisteme yeni bir yazar profili oluşturun.</p>

<div class="lms-card">
    <div class="lms-card-body">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="border:none;background:#ffdad6;color:#93000a;border-radius:8px;"></div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="FirstName" class="lms-label">Ad</label>
                    <input asp-for="FirstName" class="lms-input" placeholder="Yazarın adı" />
                    <span asp-validation-for="FirstName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="LastName" class="lms-label">Soyad</label>
                    <input asp-for="LastName" class="lms-input" placeholder="Yazarın soyadı" />
                    <span asp-validation-for="LastName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Email" class="lms-label">E-posta</label>
                    <div style="position:relative;">
                        <span style="position:absolute;left:14px;top:50%;transform:translateY(-50%);color:#76777f;"><i class="bi bi-at"></i></span>
                        <input asp-for="Email" class="lms-input" type="email" placeholder="ornek@email.com" style="padding-left:34px;" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="BirthDate" class="lms-label">Doğum Tarihi</label>
                    <input asp-for="BirthDate" class="lms-input" type="date" />
                </div>
                <div class="col-12">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <label asp-for="Bio" class="lms-label" style="margin-bottom:0;">Biyografi</label>
                        <small style="color:#76777f;">İsteğe bağlı</small>
                    </div>
                    <textarea asp-for="Bio" class="lms-textarea" rows="4" placeholder="Yazar hakkında kısa bir bilgi giriniz..."></textarea>
                </div>
            </div>
            <hr style="margin:24px 0;border-color:#e7e8ec;" />
            <div class="d-flex justify-content-end gap-2">
                <a asp-action="Index" class="lms-btn-outline">İptal</a>
                <button type="submit" class="lms-btn-success"><i class="bi bi-floppy"></i>Kaydet</button>
            </div>
        </form>
    </div>
</div>
@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }

@{
    ViewData["Title"] = "Ana Sayfa";
    var stats = ViewBag.Stats;
}

<div class="row mb-4">
    <div class="col-12">
        <h2 class="fw-bold text-dark"><i class="bi bi-house-door me-2 text-primary"></i>Ana Sayfa</h2>
        <p class="text-muted">LibraryMS Kitap Yönetim Sistemine hoş geldiniz.</p>
    </div>
</div>

<!-- İstatistik Kartları -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card stat-card p-3 text-center">
            <i class="bi bi-book" style="font-size:2rem;"></i>
            <h3 class="mt-2 mb-0 fw-bold">@stats.Books</h3>
            <p class="mb-0 opacity-75">Toplam Kitap</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card p-3 text-center" style="background:linear-gradient(135deg,#00695c,#00897b);color:white;border-radius:12px;">
            <i class="bi bi-person-lines-fill" style="font-size:2rem;"></i>
            <h3 class="mt-2 mb-0 fw-bold">@stats.Authors</h3>
            <p class="mb-0 opacity-75">Toplam Yazar</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card p-3 text-center" style="background:linear-gradient(135deg,#e65100,#ef6c00);color:white;border-radius:12px;">
            <i class="bi bi-tags" style="font-size:2rem;"></i>
            <h3 class="mt-2 mb-0 fw-bold">@stats.Categories</h3>
            <p class="mb-0 opacity-75">Toplam Kategori</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card p-3 text-center" style="background:linear-gradient(135deg,#4a148c,#6a1b9a);color:white;border-radius:12px;">
            <i class="bi bi-cart3" style="font-size:2rem;"></i>
            <h3 class="mt-2 mb-0 fw-bold">@stats.Orders</h3>
            <p class="mb-0 opacity-75">Toplam Sipariş</p>
        </div>
    </div>
</div>

<!-- Hızlı Erişim -->
<div class="row g-3">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-lightning-charge me-2"></i>Hızlı Erişim</h5>
            </div>
            <div class="card-body">
                <div class="d-flex flex-wrap gap-2">
                    <a asp-controller="Book" asp-action="Create" class="btn btn-outline-primary">
                        <i class="bi bi-plus-circle me-1"></i>Yeni Kitap
                    </a>
                    <a asp-controller="Author" asp-action="Create" class="btn btn-outline-success">
                        <i class="bi bi-person-plus me-1"></i>Yeni Yazar
                    </a>
                    <a asp-controller="Book" asp-action="CategoryCreate" class="btn btn-outline-warning">
                        <i class="bi bi-tag me-1"></i>Yeni Kategori
                    </a>
                    <a asp-controller="Author" asp-action="OrderCreate" class="btn btn-outline-info">
                        <i class="bi bi-cart-plus me-1"></i>Yeni Sipariş
                    </a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0"><i class="bi bi-file-earmark-bar-graph me-2"></i>Raporlar</h5>
            </div>
            <div class="card-body">
                <p class="text-muted">Stored procedure kullanarak kitap raporu görüntüleyin.</p>
                <a asp-controller="Home" asp-action="Report" class="btn btn-success">
                    <i class="bi bi-file-earmark-bar-graph me-2"></i>Kitap Raporunu Görüntüle
                </a>
            </div>
        </div>
    </div>
</div>

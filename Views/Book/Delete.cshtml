@model LibraryMS.Models.Book
@{
    ViewData["Title"] = "Kitap Sil";
}
<div class="d-flex justify-content-center" style="padding-top:20px;">
    <div class="lms-card" style="max-width:640px;width:100%;border-top:4px solid #dc2626;">
        <div style="padding:24px 28px;border-bottom:1px solid var(--lms-border);display:flex;align-items:center;gap:16px;">
            <div style="width:48px;height:48px;border-radius:50%;background:#ffdad6;color:#dc2626;display:flex;align-items:center;justify-content:center;font-size:1.3rem;">
                <i class="bi bi-trash3"></i>
            </div>
            <div>
                <div style="font-size:1.2rem;font-weight:700;color:#dc2626;">Kitap Sil</div>
                <div style="color:#76777f;font-size:0.88rem;">Bu eylem veritabanından kaydı tamamen kaldıracaktır.</div>
            </div>
        </div>
        <div class="lms-card-body">
            <div style="background:#ffdad6;border-radius:10px;padding:16px;display:flex;gap:12px;color:#93000a;margin-bottom:18px;">
                <i class="bi bi-exclamation-triangle" style="font-size:1.2rem;"></i>
                <div>
                    <div style="font-weight:700;margin-bottom:4px;">Dikkat!</div>
                    <div style="font-size:0.9rem;">Bu kitabı silmek istediğinizden emin misiniz? Bu işlem geri alınamaz ve kitapla ilişkili geçmiş ödünç kayıtları anonimleştirilecektir.</div>
                </div>
            </div>

            <div style="border:1px solid var(--lms-border);border-radius:10px;overflow:hidden;">
                <div style="padding:10px 16px;background:#fafbfd;border-bottom:1px solid var(--lms-border);font-size:0.78rem;font-weight:700;color:#45464e;letter-spacing:0.04em;text-transform:uppercase;">
                    <i class="bi bi-book me-2"></i>KİTAP DETAYLARI
                </div>
                <div style="padding:6px 16px;">
                    <div class="d-flex justify-content-between" style="padding:12px 0;border-bottom:1px solid #f1f2f4;"><span style="color:#76777f;">Kitap Adı</span><span style="font-weight:600;">@Model.Title</span></div>
                    <div class="d-flex justify-content-between" style="padding:12px 0;border-bottom:1px solid #f1f2f4;"><span style="color:#76777f;">Yazar</span><span style="font-weight:600;">@Model.Author?.FullName</span></div>
                    <div class="d-flex justify-content-between" style="padding:12px 0;border-bottom:1px solid #f1f2f4;"><span style="color:#76777f;">Barkod</span><span style="font-weight:600;">@Model.ISBN</span></div>
                    <div class="d-flex justify-content-between" style="padding:12px 0;"><span style="color:#76777f;">Kategori</span><span class="lms-badge lms-badge-blue">@Model.Category?.Name</span></div>
                </div>
            </div>
        </div>
        <div style="padding:18px 24px;background:#fafbfd;border-top:1px solid var(--lms-border);border-radius:0 0 12px 12px;display:flex;justify-content:flex-end;gap:10px;">
            <a asp-action="Index" class="lms-btn-outline">Vazgeç</a>
            <form asp-action="Delete" style="display:inline;">
                <input type="hidden" asp-for="BookId" />
                <button type="submit" class="lms-btn-danger"><i class="bi bi-trash3"></i>Evet, Sil</button>
            </form>
        </div>
    </div>
</div>

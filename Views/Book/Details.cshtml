@model LibraryMS.Models.Book
@{
    ViewData["Title"] = "Kitap Detayı";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="bi bi-eye me-2 text-info"></i>Kitap Detayı</h2>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Geri</a>
</div>
<div class="card">
    <div class="card-header bg-info text-white">
        <h5 class="mb-0"><i class="bi bi-book me-2"></i>@Model.Title</h5>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3"><i class="bi bi-upc me-1"></i>ISBN</dt><dd class="col-sm-9"><code>@Model.ISBN</code></dd>
            <dt class="col-sm-3"><i class="bi bi-currency-dollar me-1"></i>Fiyat</dt><dd class="col-sm-9"><span class="badge bg-success fs-6">@Model.Price.ToString("C2")</span></dd>
            <dt class="col-sm-3"><i class="bi bi-boxes me-1"></i>Stok</dt><dd class="col-sm-9">@Model.Stock adet</dd>
            <dt class="col-sm-3"><i class="bi bi-person me-1"></i>Yazar</dt><dd class="col-sm-9">@Model.Author?.FullName</dd>
            <dt class="col-sm-3"><i class="bi bi-tag me-1"></i>Kategori</dt><dd class="col-sm-9"><span class="badge bg-primary">@Model.Category?.Name</span></dd>
            <dt class="col-sm-3"><i class="bi bi-calendar me-1"></i>Yayın Tarihi</dt><dd class="col-sm-9">@(Model.PublishDate?.ToString("dd MMMM yyyy") ?? "Belirtilmemiş")</dd>
        </dl>
        <div class="d-flex gap-2 mt-3">
            <a asp-action="Edit" asp-route-id="@Model.BookId" class="btn btn-warning"><i class="bi bi-pencil-square me-1"></i>Düzenle</a>
            <a asp-action="Delete" asp-route-id="@Model.BookId" class="btn btn-danger"><i class="bi bi-trash3 me-1"></i>Sil</a>
        </div>
    </div>
</div>

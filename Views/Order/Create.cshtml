@model LibraryMS.Models.Order
@{
    ViewData["Title"] = "Yeni Sipariş";
}
<div class="d-flex align-items-center gap-2 mb-3">
    <a asp-action="OrderIndex" class="lms-icon-action" title="Geri"><i class="bi bi-arrow-left"></i></a>
    <h1 class="lms-page-title">Yeni Sipariş Oluştur</h1>
</div>

<form asp-action="OrderCreate">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="border:none;background:#ffdad6;color:#93000a;border-radius:8px;"></div>
    <div class="row g-3">
        <div class="col-lg-8">
            <div class="lms-card mb-3">
                <div class="lms-card-body">
                    <h5 style="font-weight:700;color:#081534;margin-bottom:14px;">Müşteri Bilgileri</h5>
                    <hr style="margin-top:0;border-color:#e7e8ec;" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="CustomerName" class="lms-label">Müşteri Adı</label>
                            <input asp-for="CustomerName" class="lms-input" placeholder="Örn: Ahmet Yılmaz" />
                            <span asp-validation-for="CustomerName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CustomerEmail" class="lms-label">E-posta Adresi</label>
                            <input asp-for="CustomerEmail" class="lms-input" type="email" placeholder="ornek@email.com" />
                            <span asp-validation-for="CustomerEmail" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="lms-card">
                <div class="lms-card-body">
                    <h5 style="font-weight:700;color:#081534;margin-bottom:14px;">Sipariş Detayları</h5>
                    <hr style="margin-top:0;border-color:#e7e8ec;" />
                    <div class="lms-form-group">
                        <label asp-for="BookId" class="lms-label">Kitap Seçimi</label>
                        <div style="position:relative;">
                            <span style="position:absolute;left:14px;top:50%;transform:translateY(-50%);color:#76777f;"><i class="bi bi-search"></i></span>
                            <select asp-for="BookId" asp-items="ViewBag.BookId" class="lms-select" id="bookSelect" style="padding-left:36px;">
                                <option value="">Kitap adı, yazar veya ISBN ara...</option>
                            </select>
                        </div>
                        <span asp-validation-for="BookId" class="text-danger small"></span>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Quantity" class="lms-label">Adet</label>
                            <input asp-for="Quantity" class="lms-input" type="number" min="1" max="100" id="quantityInput" value="1" />
                            <span asp-validation-for="Quantity" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Status" class="lms-label">Durum</label>
                            <select asp-for="Status" class="lms-select">
                                <option value="Beklemede">Bekliyor</option>
                                <option value="Tamamlandı">Tamamlandı</option>
                                <option value="İptal">İptal</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="lms-card" style="position:sticky;top:84px;">
                <div class="lms-card-body">
                    <h5 style="font-weight:700;color:#081534;margin-bottom:14px;">Sipariş Özeti</h5>
                    <div style="background:#f2f3f7;border-radius:10px;padding:18px;text-align:center;color:#76777f;font-size:0.88rem;border:1px dashed #d1d5db;">
                        Henüz kitap seçilmedi.<br />Lütfen listeden kitap ekleyin.
                    </div>
                    <div class="d-flex justify-content-between mt-3" style="color:#45464e;"><span>Ara Toplam</span><span>0.00 TL</span></div>
                    <div class="d-flex justify-content-between mt-1" style="color:#45464e;"><span>Vergi (%10)</span><span>0.00 TL</span></div>
                    <hr style="border-color:#e7e8ec;" />
                    <div class="d-flex justify-content-between align-items-center"><span style="font-weight:700;color:#081534;font-size:1.05rem;">Genel Toplam</span><span style="font-weight:700;color:#081534;font-size:1.3rem;">0.00 TL</span></div>
                    <button type="submit" class="lms-btn-primary w-100 mt-3" style="justify-content:center;"><i class="bi bi-check-circle"></i>Siparişi Oluştur</button>
                    <a asp-action="OrderIndex" class="lms-btn-outline w-100 mt-2" style="justify-content:center;">İptal</a>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }

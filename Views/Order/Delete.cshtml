@model LibraryMS.Models.Order
@{
    ViewData["Title"] = "Sipariş Sil";
}
<div class="d-flex justify-content-center" style="padding-top:20px;">
    <div class="lms-card" style="max-width:680px;width:100%;">
        <div class="lms-card-body">
            <div class="d-flex gap-3 mb-3">
                <div style="width:42px;height:42px;border-radius:50%;background:#ffdad6;color:#dc2626;display:flex;align-items:center;justify-content:center;font-size:1.2rem;flex-shrink:0;">
                    <i class="bi bi-exclamation-triangle"></i>
                </div>
                <div>
                    <h4 style="margin:0;font-weight:700;color:#081534;">Siparişi Silmek İstediğinize Emin Misiniz?</h4>
                    <p style="margin:6px 0 0;color:#76777f;">Bu işlem geri alınamaz. Sipariş kayıtları sistemden kalıcı olarak silinecektir.</p>
                </div>
            </div>

            <div class="row g-3 mt-1">
                <div class="col-md-6">
                    <div style="font-size:0.72rem;font-weight:700;color:#76777f;letter-spacing:0.04em;text-transform:uppercase;margin-bottom:6px;">MÜŞTERİ BİLGİLERİ</div>
                    <div style="background:#fafbfd;border-radius:10px;padding:14px;">
                        <div style="font-weight:700;color:#081534;">@Model.CustomerName</div>
                        <div style="color:#76777f;font-size:0.88rem;"><i class="bi bi-envelope me-1"></i>@Model.CustomerEmail</div>
                        <div style="color:#76777f;font-size:0.88rem;"># Sipariş No: ORD-@Model.OrderId.ToString("D4")</div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div style="font-size:0.72rem;font-weight:700;color:#76777f;letter-spacing:0.04em;text-transform:uppercase;margin-bottom:6px;">SİPARİŞ ÖZETİ</div>
                    <div style="background:#fafbfd;border-radius:10px;padding:14px;">
                        <div style="font-size:0.78rem;color:#76777f;">Toplam Tutar</div>
                        <div style="font-weight:700;color:#081534;font-size:1.3rem;">₺@Model.TotalAmount.ToString("N2")</div>
                        <div style="margin-top:6px;">
                            @if (Model.Status == "Tamamlandı") { <span class="lms-badge lms-badge-green">@Model.Status</span> }
                            else if (Model.Status == "İptal") { <span class="lms-badge lms-badge-red">@Model.Status</span> }
                            else { <span class="lms-badge lms-badge-yellow">@Model.Status</span> }
                        </div>
                    </div>
                </div>
            </div>

            <div style="margin-top:18px;">
                <div style="font-size:0.72rem;font-weight:700;color:#76777f;letter-spacing:0.04em;text-transform:uppercase;margin-bottom:6px;">SİPARİŞ EDİLEN KİTAPLAR</div>
                <table class="lms-table" style="border:1px solid var(--lms-border);border-radius:10px;overflow:hidden;">
                    <thead>
                        <tr>
                            <th>Kitap Adı</th>
                            <th>Yazar</th>
                            <th class="text-end">Adet</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td style="font-weight:600;">@Model.Book?.Title</td>
                            <td>@Model.Book?.Author?.FullName</td>
                            <td class="text-end">@Model.Quantity</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
        <div style="padding:16px 24px;background:#fafbfd;border-top:1px solid var(--lms-border);border-radius:0 0 12px 12px;display:flex;justify-content:flex-end;gap:10px;">
            <a asp-action="OrderIndex" class="lms-btn-outline">İptal Et</a>
            <form asp-action="OrderDelete" style="display:inline;">
                <input type="hidden" asp-for="OrderId" />
                <button type="submit" class="lms-btn-danger"><i class="bi bi-trash3"></i>Siparişi Sil</button>
            </form>
        </div>
    </div>
</div>

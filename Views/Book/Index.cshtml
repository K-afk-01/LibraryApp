@model IEnumerable<LibraryMS.Models.Book>
@{
    ViewData["Title"] = "Kitaplar";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="bi bi-book me-2 text-primary"></i>Kitaplar</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>Yeni Kitap Ekle
    </a>
</div>
<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Kitap Adı</th>
                        <th>ISBN</th>
                        <th>Fiyat</th>
                        <th>Yazar</th>
                        <th>Kategori</th>
                        <th>Stok</th>
                        <th>Yayın Tarihi</th>
                        <th class="text-center">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@item.Title</td>
                            <td><code>@item.ISBN</code></td>
                            <td><span class="badge bg-success">@item.Price.ToString("C2")</span></td>
                            <td>@item.Author?.FullName</td>
                            <td><span class="badge bg-primary">@item.Category?.Name</span></td>
                            <td>
                                @if (item.Stock <= 5) {
                                    <span class="badge bg-danger">@item.Stock</span>
                                } else {
                                    <span class="badge bg-info text-dark">@item.Stock</span>
                                }
                            </td>
                            <td>@(item.PublishDate?.ToString("dd.MM.yyyy") ?? "-")</td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@item.BookId" class="btn btn-outline-info btn-action" title="Detay">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.BookId" class="btn btn-outline-warning btn-action" title="Düzenle">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.BookId" class="btn btn-outline-danger btn-action" title="Sil">
                                    <i class="bi bi-trash3"></i>
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="8" class="text-center text-muted py-4"><i class="bi bi-inbox fs-3 d-block mb-2"></i>Henüz kitap eklenmemiş.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
